{
  "name": "local-cors-proxy-root",
  "version": "1.3.0",
  "scripts": {
    "start": "bun ./lcp.ts",
    "build": "bun build lcp.ts --target=node --outdir dist/",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "lcp": "./dist/lcp.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/local-cors-proxy-root.git"
  },
  "keywords": [
    "cors",
    "proxy",
    "simple",
    "node",
    "fastify"
  ],
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "chalk": "latest",
    "command-line-args": "latest",
    "fastify": "^5.6.1",
    "got": "^14.6.6"
  },
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@types/bun": "latest"
  }
}
